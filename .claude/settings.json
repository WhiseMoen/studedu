{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rmdir /s:*)",
      "Bash(del /s:*)",
      "Bash(format:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard origin:*)"
    ]
  }
}
